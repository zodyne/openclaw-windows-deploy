{
  "auth": {
    "profiles": {
      "zai:default": {
        "provider": "zai",
        "mode": "api_key"
      }
    }
  },
  "env": {
    "vars": {
      "NO_PROXY": "localhost,127.0.0.1,::1",
      "no_proxy": "localhost,127.0.0.1,::1"
    }
  },
  "models": {
    "mode": "replace",
    "providers": {
      "novasky": {
        "baseUrl": "https://api.deepseek.com/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-v4-pro",
            "name": "DeepSeek V4 Pro",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 128000,
            "compat": { "supportsDeveloperRole": false }
          }
        ],
        "apiKey": "DEEPSEEK_API_KEY_PLACEHOLDER",
        "request": { "allowPrivateNetwork": false },
        "timeoutSeconds": 120
      },
      "zai": {
        "baseUrl": "https://open.bigmodel.cn/api/anthropic",
        "apiKey": "ZHIPU_API_KEY_PLACEHOLDER",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "glm-5.2",
            "name": "GLM-5.2",
            "api": "anthropic-messages",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 32768
          }
        ],
        "timeoutSeconds": 60
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-5.2",
        "fallbacks": ["novasky/deepseek-v4-pro"]
      },
      "models": {
        "zai/glm-5.2": { "alias": "GLM" },
        "novasky/deepseek-v4-pro": { "alias": "DeepSeek" }
      },
      "workspace": "WORKSPACE_PATH_PLACEHOLDER",
      "thinkingDefault": "xhigh",
      "subagents": {
        "delegationMode": "suggest",
        "maxConcurrent": 1,
        "maxSpawnDepth": 1,
        "maxChildrenPerAgent": 3,
        "archiveAfterMinutes": 60
      },
      "maxConcurrent": 2,
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "bge-m3",
        "outputDimensionality": 1024,
        "remote": {
          "baseUrl": "http://127.0.0.1:11434/v1",
          "apiKey": "ollama"
        }
      },
      "imageModel": {
        "primary": "zai/glm-5.2"
      },
      "runRetries": {
        "base": 10,
        "perProfile": 3,
        "min": 15
      },
      "contextLimits": {
        "toolResultMaxChars": 50000,
        "memoryGetMaxChars": 30000,
        "postCompactionMaxChars": 12000
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main",
        "workspace": "WORKSPACE_PATH_PLACEHOLDER",
        "identity": { "name": "Main", "emoji": "🧭" }
      }
    ]
  },
  "tools": {
    "web": { "search": { "enabled": false } }
  },
  "bindings": [],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": false
    },
    "auth": {
      "mode": "token",
      "token": "DEPLOY_TOKEN_PLACEHOLDER"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "mcp": {
    "servers": {}
  },
  "plugins": {
    "entries": {
      "memory-core": { "config": {} },
      "acpx": {
        "enabled": false,
        "config": {
          "permissionMode": "approve-reads",
          "timeoutSeconds": 120
        }
      },
      "codex-supervisor": { "enabled": true }
    },
    "allow": ["acpx", "codex-supervisor", "memory-core"],
    "bundledDiscovery": "compat"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "cron": {
    "maxConcurrentRuns": 8
  },
  "acp": {
    "enabled": true,
    "defaultAgent": "claude",
    "allowedAgents": ["claude", "codex"]
  },
  "skills": {
    "entries": {}
  }
}
